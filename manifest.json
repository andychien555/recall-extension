{
  "manifest_version": 3,
  "name": "Recall",
  "description": "一鍵儲存 Threads 貼文為本機 .md 檔案",
  "version": "0.2.0",
  "permissions": [
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://www.threads.net/*",
    "https://www.threads.com/*",
    "https://threads.net/*",
    "https://threads.com/*",
    "https://x.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.threads.net/*",
        "https://www.threads.com/*",
        "https://threads.net/*",
        "https://threads.com/*"
      ],
      "js": ["content/threads.js"],
      "css": ["content/threads.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["images/*.png"],
      "matches": ["https://www.threads.net/*", "https://www.threads.com/*", "https://threads.net/*", "https://threads.com/*"]
    }
  ]
}
